{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/panel", "dest": "/public/panel.html" },
    { "src": "/panel.html", "dest": "/public/panel.html" },
    { "src": "/(.*\\.(js|css|jpg|png))", "dest": "/public/$1" },
    { "src": "/", "dest": "/index.html" }
  ]
}
